PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_change_this_in_production
DATABASE_URL=sqlite:///./crm.db
# For PostgreSQL, use: postgresql://user:password@localhost:5432/crm_db
LOG_LEVEL=info
DEFAULT_ADMIN_EMAIL=test@evpower.com
DEFAULT_ADMIN_PASSWORD=password123
DEFAULT_ADMIN_NAME=Test User
FRONTEND_URL=http://localhost:3000
# Optional second frontend origin for production (e.g. Vercel preview/custom domain)
FRONTEND_URL_2=
# Optional: force allow all origins (use only if frontend origin is dynamic)
CORS_ALLOW_ALL=false
